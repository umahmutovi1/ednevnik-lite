# =============================================================================
# Dnevnik-Lite — .env.example
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control — it is listed in .gitignore.
# =============================================================================

# --- Flask Core ---
# Must be a cryptographically random string (min 32 bytes).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=43272165fb04d50da023cd97c00016be272aeac1dcaa70a839abd0c4f76fb909

# --- JWT ---
# Separate key from SECRET_KEY — compromise of one does not break the other.
# Generate the same way as SECRET_KEY.
JWT_SECRET_KEY=59a859df2117382d69fa6d45818785b3754f640f344a4c6dc2e675f6b9e65c6e

# --- Database ---
# Format: postgresql://user:password@host:port/dbname
# Production MUST append ?sslmode=require
DATABASE_URL=postgresql://dnevnik_user:neka_sifra@localhost:5432/dnevnik_lite

# --- Environment ---
# One of: development | testing | production
FLASK_ENV=development

# --- bcrypt Work Factor ---
# 12 for production (slow = secure), 4 for testing (fast = practical)
BCRYPT_LOG_ROUNDS=12

# --- Rate Limiting ---
# Redis URI for Flask-Limiter in production.
# If not set, falls back to in-memory (NOT suitable for multi-process production).
# Format: redis://[:password@]host[:port][/db]
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Example: https://app.skola.ba,https://admin.skola.ba
# Use * ONLY in development — never in production.
CORS_ORIGINS=http://localhost:3000

# --- Admin Bootstrap ---
# Used only during `flask seed-admin` — creates the first admin account.
# Remove from .env after first run.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# --- Optional: Talisman (HTTPS) ---
# Set to 1 to force HTTPS redirect. Set to 0 in local HTTP dev.
FORCE_HTTPS=0
