# =============================================================================
# Dnevnik-Lite — .gitignore
# =============================================================================

# --- CRITICAL: Never commit secrets ---
.env

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/
*.pyo

# --- Virtual Environment ---
venv/
.venv/
env/
ENV/

# --- Flask / SQLAlchemy ---
instance/
*.sqlite3
*.db

# --- Flask-Migrate (generated, not static) ---
# Keep migrations/versions/ tracked — it's schema history
# But exclude compiled .pyc inside it
migrations/__pycache__/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- Logs ---
*.log
logs/

# --- OS ---
Thumbs.db
.scannerwork/
